# =========================
# glm2api 示例配置
# =========================
# 使用方式：
# 1. 复制本文件为 `.env`
# 2. 填写 `GLM_REFRESH_TOKEN`，或开启游客模式
# 3. 按需修改监听地址、开放模型、服务鉴权等配置

# ---------------------------------
# 服务监听配置
# ---------------------------------
# 服务监听地址。
# 本机自用通常填 127.0.0.1；局域网共享可以改为 0.0.0.0。
HOST=127.0.0.1

# 服务端口。
# OpenAI SDK 常见写法会连到 http://127.0.0.1:8000/v1，所以默认保持 8000。
PORT=8000

# OpenAI 兼容接口前缀。
# 一般保持 /v1 即可，除非你已有反向代理规则。
API_PREFIX=/v1

# 日志级别：DEBUG / INFO / WARNING / ERROR
# 想看详细请求过程可改成 DEBUG。
LOG_LEVEL=INFO

# 调试狂暴模式。
# true: 自动切到 DEBUG，并打印入站原始请求、上游原始请求/响应、SSE 原文、工具调用转换等几乎所有调试信息。
DEBUG_DUMP_ALL=false

# 上游请求超时时间，单位秒。
# GLM Web 端在长回答和联网场景下会比较慢，默认给 120 秒更稳妥。
REQUEST_TIMEOUT_SECONDS=120

# CORS 允许来源。
# v35 修复：默认留空（不发 CORS header，与官方 OpenAI API 一致）。
# 官方 OpenAI API 不返回 Access-Control-Allow-Origin。
# 仅当需要浏览器跨域访问管理面板（/admin）时才配置具体来源（如 https://your-domain.com）。
# 不要用 *（会被识别为逆向特征）。
CORS_ALLOW_ORIGIN=

# ---------------------------------
# 本服务自身鉴权（可选）
# ---------------------------------
# 如果你希望别人访问本地代理时也必须带 Bearer Token，可以在这里配置。
# 多个 key 用英文逗号分隔，例如：
# SERVER_API_KEYS=sk-local-1,sk-local-2
# 留空表示不校验访问者。
SERVER_API_KEYS=

# ---------------------------------
# GLM / 智谱清言上游配置
# ---------------------------------
# 多账号 token 文件路径。
# 文件中每行一个 refresh_token，程序会优先使用这里的账号列表。
# 当某个账号请求失败时，会自动切到下一行账号继续尝试。
GLM_TOKEN_FILE=token.txt

# 单账号兜底配置。
# 如果没有 token.txt，才会使用这里的 refresh_token。
# 如果上游返回了新的 refresh_token，单账号模式下会自动写回当前 `.env` 文件；
# 多账号模式下则会写回 token.txt 对应账号行。
GLM_REFRESH_TOKEN=

# 显式启用游客 ck。
# true: 忽略 token.txt 和 GLM_REFRESH_TOKEN，直接走游客 token
# false: 正常优先使用 refresh_token；但如果完全没配 token，仍会自动退回游客模式
# 游客模式会按 GLM_MAX_CONCURRENCY 自动创建同等数量的游客账号槽位
GLM_USE_GUEST_REFRESH_TOKEN=false

# GLM Web 端基础地址。
# 默认已经对应 docs 中的 chatglm Web 接口，不建议修改。
GLM_BASE_URL=https://chatglm.cn/chatglm

# 默认 assistant_id
# docs 里使用的是 65940acff94777010aa6b796
# 大多数场景保留默认即可；如果你有自己的专属助手，也可以替换
GLM_ASSISTANT_ID=65940acff94777010aa6b796

# 图片生成接口默认使用的绘图 assistant_id
GLM_IMAGE_ASSISTANT_ID=65a232c082ff90a2ad2f15e2

# 是否在每次回答后删除 GLM 会话。
# true: 更干净，减少网页端聊天记录堆积
# false: 保留会话，方便你在上游网页端排查
GLM_DELETE_CONVERSATION=true

# 允许同时占用的上游执行槽位数量。
# 默认 3，适合本地多客户端并发；如果你的账号风控较严，可以手动调回 1。
# 这个值同时决定会预创建多少个独立游客账号槽位。
GLM_MAX_CONCURRENCY=100

# 多请求排队最大等待时间，单位秒。
# 当并发请求超过上面的执行槽位数量时，会在这里等待空闲槽位。
GLM_QUEUE_WAIT_TIMEOUT_SECONDS=600

# 当 GLM 返回“请等待其他对话生成完毕”时，最多自动重试多少次。
# 这个重试主要用于兜住“网页端还有其他会话在生成”的情况。
GLM_BUSY_MAX_RETRIES=30

# 触发上面的忙碌重试时，两次重试之间等待多久，单位秒。
GLM_BUSY_RETRY_INTERVAL_SECONDS=2

# 游客 ck 请求失败时，最多自动重新拉取游客 token 并重试多少次。
GLM_GUEST_MAX_RETRIES=3

# 工具黑名单，多个名字用英文逗号分隔。
# 这些工具不会被注入到提示词里；即使模型仍然输出对应调用，也会在服务端被丢弃。
# 2API 不支持 web 端浏览器工具时，保留默认值即可。
BLOCKED_TOOL_NAMES=open_url,open_ul,browser.open,web.run,web.open,web.search,web_search,browse,open_link

# 自定义 User-Agent。
# 只有在你明确知道要伪装成其他浏览器时再改。
GLM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36 Edg/143.0.0.0

# ---------------------------------
# 主动轮换：每个 device_id 用 N 次后预换
# ---------------------------------
# 0=关闭（被动等风控才换）
# 默认 8：把风控窗口前的请求都打到新 device_id，避免被动风控
GLM_DEVICE_ID_ROTATE_THRESHOLD=8

# ---------------------------------
# 输入校验
# ---------------------------------
# 严格校验模式开关（默认关闭，Claude Code 友好）
# 启用后（true/1/yes）：
#   - Content-Type 必须是 application/json，否则返回 415
#   - /v1/messages 必须带 anthropic-version header，否则返回 400
# 不启用时：宽松接受所有请求（默认，推荐 Claude Code 接入场景）
STRICT_VALIDATION=false

# 严格模型校验开关（默认关闭，宽松 fallback）
# 启用后：不存在的模型返回 404（而非 fallback 到 glm-5.2-flash）
# 不启用时：未知模型自动 fallback 到 glm-5.2-flash（默认，Claude Code 友好）
STRICT_MODEL_VALIDATION=false

# ---------------------------------
# 管理面板
# ---------------------------------
# 访问 http://host:port/admin 时使用的密码
# 留空时：使用 SERVER_API_KEYS 第一个值，或默认 "admin"
ADMIN_PASSWORD=change-me-to-a-strong-password
