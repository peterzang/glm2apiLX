# Render 平台部署示例环境变量
# 
# 使用方式：
# 1. 在 Render Dashboard 的 "Environment" 标签页中设置这些变量
# 2. 敏感信息（ADMIN_PASSWORD / SERVER_API_KEYS）不要提交到 git
#
# Render 会自动注入：
# - PORT: Render 自动分配的端口（不需要手动设置）
#
# 必须在 Render Dashboard 中设置的变量：

# 服务监听地址（Render 要求 0.0.0.0）
HOST=0.0.0.0

# OpenAI 兼容接口前缀
API_PREFIX=/v1

# 日志级别
LOG_LEVEL=INFO

# 调试模式（生产环境关闭）
DEBUG_DUMP_ALL=false

# 游客模式（无需 GLM_REFRESH_TOKEN）
GLM_USE_GUEST_REFRESH_TOKEN=true

# 最大并发数（Render 免费版建议 8）
GLM_MAX_CONCURRENCY=8

# 管理面板密码（在 Render Dashboard 中设置，敏感信息）
ADMIN_PASSWORD=change-me-to-a-strong-password

# API 密钥（在 Render Dashboard 中设置，留空则不需要鉴权）
SERVER_API_KEYS=

# 可选：GLM 刷新 token（如果不用游客模式）
# GLM_REFRESH_TOKEN=your_token_here
